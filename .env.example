# ===========================================
# IATRS - Intelligent Applicant Tracking System
# Environment Configuration (Complete)
# ===========================================

# -------------------------------------------
# Application Settings
# -------------------------------------------
APP_NAME=Intelligent ATS
APP_VERSION=2.0.0
DEBUG=true
FRONTEND_URL=http://localhost:8000/frontend

# -------------------------------------------
# Database Configuration
# -------------------------------------------
DATABASE_URL=mysql+pymysql://ats_user:ats_pass@localhost:3306/iatrs
AUTO_CREATE_TABLES=true

# Legacy MySQL settings (for older scripts)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Killer@12345
DB_NAME=iatrs

# -------------------------------------------
# JWT Authentication
# -------------------------------------------
JWT_SECRET_KEY=change-this-secret-in-production-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# -------------------------------------------
# OAuth2 Configuration (Optional)
# -------------------------------------------
# Google OAuth2 - Get from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# LinkedIn OAuth2 - Get from https://www.linkedin.com/developers/
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# -------------------------------------------
# CORS Settings
# -------------------------------------------
CORS_ORIGINS=*

# -------------------------------------------
# File Upload Settings
# -------------------------------------------
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# -------------------------------------------
# Email Configuration (SMTP)
# -------------------------------------------
ENABLE_EMAIL=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@iatrs.com
FROM_NAME=IATRS

# -------------------------------------------
# Redis Cache (Optional)
# -------------------------------------------
ENABLE_CACHE=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# -------------------------------------------
# Rate Limiting (Optional)
# -------------------------------------------
ENABLE_RATE_LIMIT=false
RATE_LIMIT_PER_MINUTE=60

# -------------------------------------------
# AI Features
# -------------------------------------------
ENABLE_AI_FEATURES=true
AI_MODEL_PATH=

# -------------------------------------------
# Security Settings
# -------------------------------------------
BCRYPT_ROUNDS=12
ENABLE_2FA=false

# -------------------------------------------
# Logging Configuration
# -------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/iatrs.log

# -------------------------------------------
# Pagination Settings
# -------------------------------------------
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# -------------------------------------------
# Server Settings
# -------------------------------------------
HOST=127.0.0.1
PORT=8000
UVICORN_RELOAD=true
